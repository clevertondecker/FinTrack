<?xml version="1.0"?>
<!DOCTYPE suppressions PUBLIC
    "-//Checkstyle//DTD SuppressionFilter Configuration 1.2//EN"
    "https://checkstyle.org/dtds/suppressions_1_2.dtd">

<suppressions>
    <!-- Allow star imports in test files -->
    <suppress files=".*Test\.java$" checks="AvoidStarImport"/>
    <suppress files=".*Tests\.java$" checks="AvoidStarImport"/>
    <!-- CreditCard factory needs 9 params for assignedUser -->
    <suppress files="CreditCard\.java" checks="ParameterNumber"/>
    <!-- InvoiceImport has many fields/getters; InvoiceImportService orchestrates many collaborators -->
    <suppress files="InvoiceImport\.java" checks="MethodCount"/>
    <suppress files="InvoiceImportService\.java" checks="ClassFanOutComplexity"/>
</suppressions>

